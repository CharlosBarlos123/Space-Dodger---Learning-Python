import pygame
import time
import random
pygame.font.init()

WIDTH, HEIGHT = 1000, 800
WIN = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Space Dodger")

# Creating the Background Variable

BG = pygame.image.load('Space-Background-Image-2.jpg')

# Player Dimensions

PLAYER_WIDTH = 40
PLAYER_HEIGHT = 60
PLAYER_VEL = 8

# Star Dimensions

STAR_WIDTH = 10
STAR_HEIGHT = 20
STAR_VEL = 5

# Creating the font object

FONT = pygame.font.SysFont('Comic Sans MS', 25
                           )
# Drawing the Objects on the screen

def draw(player, elapsed_time, stars):
    WIN.blit(BG, (0, 0))

    time_text = FONT.render(f"Time: {round(elapsed_time)}s", 1, "white")
    WIN.blit(time_text, (10, 10))
    #Draw Player Rectangle
    pygame.draw.rect(WIN, 'red', player)
    # Code to draw the Star rectangles
    for star in stars:
        pygame.draw.rect(WIN, 'orange', star)
    # We want to refresh each change in the draw
    pygame.display.update()

# Main Game Loop

def main():
    run = True

    player = pygame.Rect(200, HEIGHT - PLAYER_HEIGHT,
                         PLAYER_WIDTH, PLAYER_HEIGHT)
    # Game needs paced with clock variable
    clock = pygame.time.Clock()
    # Keeping track of how much time has elapsed
    start_time = time.time()
    elapsed_time = 0

    # Adding the projectiles to dodge
    star_add_increment = 2000
    star_count = 0

    stars = []
    hit = False

    while run:
        star_count += clock.tick(60) #returns number of miliseconds since the last tick
        elapsed_time = time.time() - start_time

        #Adding stars to the screen, in increments of 3 stars
        if star_count > star_add_increment:
            for _ in range(3):
                # Decides where on the screen (left to right) the star appears
                star_x = random.randint(0, WIDTH - STAR_WIDTH)
                star = pygame.Rect(star_x, -STAR_HEIGHT, STAR_WIDTH, STAR_HEIGHT) #Star starts off screen
                stars.append(star)

            star_add_increment = max(200,star_add_increment - 50)
            star_count = 0

        # We want to check if the user presses the Quit button
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                run = False
                break

        # Detecting Player input and updating the image
        keys = pygame.key.get_pressed()
        if keys[pygame.K_LEFT] and player.x - PLAYER_VEL >= 0:
            player.x -= PLAYER_VEL
        if keys[pygame.K_RIGHT] and player.x + PLAYER_VEL + player.width <= WIDTH:
            player.x += PLAYER_VEL

        #Moving our stars down the screen
        for star in stars[:]: #This creates a copy of our stars list
            #since we do not want to accidentally alter the original list
            star.y += STAR_VEL
            #This one checks if the star moves off the bottom of the screen,
            # then we remove it
            if star.y > HEIGHT:
                stars.remove(star)
            #This one checks if the star hits the player, then we remove it
            elif star.y + star.height >= player.y and star.colliderect(player):
                stars.remove(star)
                hit = True
                break

        #Ending the game if you hit a star
        if hit:
            lost_text = FONT.render("You lose!", 1, (255, 255, 255))
            #Making sure the losing text shows up in the middle of the screen
            WIN.blit(lost_text, (WIDTH/2 - lost_text.get_width()/2, HEIGHT/2 - lost_text.get_height()/2))
            pygame.display.update()
            #Freeze game to see text
            pygame.time.delay(4000)
            #ends game
            break

        draw(player, elapsed_time, stars)

    pygame.quit()

if __name__ == '__main__':
    main()
